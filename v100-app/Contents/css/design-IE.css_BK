/*サブ画面設定 V70以上追加*/

/*詳細説明*/
	div#detail {
	    font-size:12pt ;
	    width:400px ;
	    position:absolute ;
	    top:24px;
	    left:120px ;
	    background:#FFFFFF ;
	    cursor:move ;
	    z-index:10 ;
        display:none;
	}
	div#detail table{
	    border: 0px ;
	    width: 400px ;
	}

/*Copyrights*/
	div.copyrights {
		display: block ; 
	    width:93%;
		position:relative ;
		top: -5px ;
		text-align:right;
		font-size:8pt;
        color:#FFFFFF;
		z-index:200;
	}

/* パーツとパーツの間に空きを作る */

img.v_spacer_s {
    display: block ;
    width: 100% ;
    height: 3px ;
}
img.h_spacer_s {
    width: 3px ;
    height: 18px ;
}

img.v_spacer_m {
    display: block ;
    width: 100% ;
    height: 5px ;
}

img.v_spacer_l {
    display: block ;
    width: 100% ;
    height: 8px ;
}
img.icon_margin{
	margin: 0px 4px 0px 0px;
	vertical-align:-10%;
}


/*JOBメニューの修飾*/


div#job-main {
    display: block ;
    font-size: 10pt ;
    width: 60px ;
    height: 15px ;
    border-bottom : solid #0000ff;

    font-family: "ＭＳ Ｐゴシック", "ヒラギノ角ゴ Pro W3", Osaka, sans-serif ;
}

div#rpt {
    display: block ;
    font-size: 10pt ;
    width: 75px ;
    height: 15px ;
    border-bottom : solid #0000ff;
    

    font-family: "ＭＳ Ｐゴシック", "ヒラギノ角ゴ Pro W3", Osaka, sans-serif ;
}


