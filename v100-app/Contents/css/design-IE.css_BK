@charset "UTF-8";
/*IE用デザインCSS*/

/* 全体設定 */
img{
 border:0 ;
}

ul { 
    margin-left: 1.2em ; 
}


/*テーブル設定*/
	td.none {
	    border:none;
	    font-size: 10pt ;
	}

	td.title {
	    border:none;
	    font-size: 12pt ;
	    
	}
	td.dttitle {
	    border:none;
	    font-size: 10pt ;
	    color: #FFF ;
	}
	td.t0 {
		border:thin solid;
	    border-bottom-width: 1px;
		border-top-width: 1px;
		border-left-width: 1px;
		border-right-width: 1px;
		border-color: #000000 ;
	    font-size: 10pt ;
	    color: #000000 ;
	}
	td.t1 {
		border:thin solid;
	    border-bottom-width: 1px;
		border-top-width: 0px;
		border-left-width: 1px;
		border-right-width: 1px;
		border-color: #000000 ;
	    font-size: 10pt ;
	    color: #000000 ;
	}


/*タイトル設定*/
div.title {
    display: block ;
    position: absolute ;
    left: 0px ;
    top: 0px ;
    width: 1070px ;
    height: 24px ;
    font-size: 16pt ;
    background-image:url("../image/_title_back.png");
    border-bottom-width: 1px; 
    border-bottom-color: #747474 ;
    border-bottom-style: solid ;
    z-index: 100 ;
    font-family: "ＭＳ Ｐゴシック", "ヒラギノ角ゴ Pro W3", Osaka, sans-serif ;
}

/*サイドメニュー設定*/
	div.sidemenu {
	    font-size: 9pt ;
		text-decoration:none;
	    z-index: 5 ;
		padding : 0;
		margin : 0;
	    border-width: 1px;
	    left: -159px ;
	    top: 24px ;
	    height: 220px ;
	    width: 190px ;
	    position: absolute ;

	    line-height:30px ;
	    background-color: #F4F4F4 ;
	    border-color: #000000 ;
	    border-style: solid ;
	    font-family: "ＭＳ Ｐゴシック", "ヒラギノ角ゴ Pro W3", Osaka, sans-serif ;
	}
	div.sidemenu img{
	 border:0 ;
	 padding-right:2px ;
	 padding-left:2px ;
	}

	div.sidemenu.dt a{
	    font-size: 9pt ;
		text-decoration:none;
	    z-index: 5 ;
		padding : 0;
		margin : 0;
	    margin-right:0px;
	    padding-right:0px;
		padding-left:0px;
	    border-width: 1px; 
		left:0px;
		top:30px;
		height:30px;
		width:100%;
		border-bottom:solid 1px #000000; 

		color:#000000;
		background-color: #F4F4F4 ;
	}



	div.sidemenu.dt a:hover{
	    font-size: 9pt ;
		text-decoration:none;
	    z-index: 5 ;
		padding : 0;
		margin : 0;
	    margin-right:0px;
	    padding-right:0px;
		padding-left:0px;
	    border-width: 1px; 
		left:0px;
		top:30px;
		height:30px;
		width:100%;
		border-bottom:solid 1px #000000; 

		color:#FFFFFF;
		background-color:#0837ae;
	}

	div.sidemenu ul{
	  list-style : none;  /*リストマークを消す*/
	  text-align:left;  
	  padding : 0;
	  margin : 0;
   }
	div.sidemenu li{
	  width : 13em;  /*リストの幅の設定*/
	  padding : 0;
	  margin : 0;
   }


/*メイン画面設定*/
div#main {
	display: block ;
    position: absolute ;
    left: 40px ;
    top: 30px ;
    width: 1000px ;
    font-size: 12pt ;
    background-color: #FFFFFF ;
    z-index: 0 ;
    font-family: "ＭＳ Ｐゴシック", "ヒラギノ角ゴ Pro W3", Osaka, sans-serif ;
}

/*サブ画面設定*/
div#sub {
    display: none ;
    position: absolute ;
    left: 40px ;
    top: 30px ;
    width: 1000px ;
    font-size: 12pt ;
    background-color: #FFFFFF ;
    z-index: 0 ;
    font-family: "ＭＳ Ｐゴシック", "ヒラギノ角ゴ Pro W3", Osaka, sans-serif ;
}
